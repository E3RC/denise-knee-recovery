# Copy this file to .env on the host and replace both placeholder values.
# Do not commit the real .env file.
ADMIN_TOKEN=replace-with-a-long-random-token-before-publish
CAREGIVER_PIN=replace-with-a-private-caregiver-pin
PUSHOVER_USER_KEY=replace-with-your-pushover-user-key
PUSHOVER_APP_TOKEN=replace-with-your-pushover-app-token
DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
PUBLIC_BASE_URL=https://your-tailscale-or-domain.example
INFISICAL_DOMAIN=https://your-self-hosted-infisical-instance
INFISICAL_PROJECT_ID=replace-with-your-infisical-project-id
INFISICAL_ENV=prod
INFISICAL_UNIVERSAL_AUTH_CLIENT_ID=replace-with-your-machine-identity-client-id
INFISICAL_UNIVERSAL_AUTH_CLIENT_SECRET=replace-with-your-machine-identity-client-secret
CADDY_DOMAIN=your-domain.example
CADDY_EMAIL=you@example.com
